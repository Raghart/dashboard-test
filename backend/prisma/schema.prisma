// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output = "./client"
}

datasource db {
  provider = "postgresql"
  schemas = ["raw", "clean", "gold"]
}

model RawCustomer {
  customer_id String @id
  customer_unique_id String?
  customer_zip_code_prefix Int?
  customer_city   String?
  customer_state  String?

  @@map("customers")
  @@schema("raw")
}

model CleanCustomer {
  customer_id String @id
  customer_unique_id String
  customer_zip_code_prefix Int
  customer_city   String
  customer_state  String
  orders CleanOrder[]

  @@map("customers")
  @@schema("clean")
}

model RawSeller {
    seller_id String @id
    seller_zip_code_prefix Int?
    seller_city String?
    seller_state String?

    @@map("sellers")
    @@schema("raw")
}

model CleanSeller {
    seller_id String @id
    seller_zip_code_prefix Int
    seller_city String
    seller_state String
    itemOrders CleanItemOrder[]

    @@map("sellers")
    @@schema("clean")
}

model RawProduct {
  product_id String @id
  product_category_name String?
  product_name_lenght Int?
  product_description_lenght Int?
  product_photos_qty Int?
  product_weight_g Int?
  product_length_cm Int?
  product_height_cm Int?
  product_width_cm Int?

  @@map("products")
  @@schema("raw")
}

model CleanProduct {
  product_id String @id
  product_category_name String
  category_name CleanCategName @relation(fields: [product_category_name], references: [product_category_name], onDelete: Cascade, onUpdate: Cascade)
  product_name_lenght Int
  product_description_lenght Int
  product_photos_qty Int
  product_weight_g Int
  product_length_cm Int
  product_height_cm Int
  product_width_cm Int
  itemProducts CleanItemOrder[]

  @@map("products")
  @@schema("clean")
}

model RawOrder {
  order_id String @id
  customer_id String?
  order_status String?
  order_purchase_timestamp DateTime?
  order_approved_at DateTime?
  order_delivered_carrier_date DateTime?
  order_delivered_customer_date DateTime?
  order_estimated_delivery_date DateTime?

  @@map("orders")
  @@schema("raw")
}

model CleanOrder {
  order_id String @id
  customer_id String 
  customer CleanCustomer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade, onUpdate: Cascade)
  order_status String
  order_purchase_timestamp DateTime
  order_approved_at DateTime
  order_delivered_carrier_date DateTime
  order_delivered_customer_date DateTime
  order_estimated_delivery_date DateTime
  orderPayments CleanOrderPayment[]
  itemOrders CleanItemOrder[]
  orderReviews CleanOrderReview[]

  @@map("orders")
  @@schema("clean")
}

model RawOrderReview {
  id Int @id @default(autoincrement())
  review_id String?
  order_id String?
  review_score Int?
  review_comment_title String?
  review_comment_message String?
  review_creation_date DateTime?
  review_answer_timestamp DateTime?

  @@map("orderReviews")
  @@schema("raw")
}

model CleanOrderReview {
  id Int @id @default(autoincrement())
  review_id String
  order_id String
  order CleanOrder @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: Cascade)
  review_score Int
  review_comment_title String?
  review_comment_message String?
  review_creation_date DateTime
  review_answer_timestamp DateTime?

  @@map("orderReviews")
  @@schema("clean")
}

model RawOrderPayment {
  id Int @id @default(autoincrement())
  order_id String?
  payment_sequential Int?
  payment_type String?
  payment_installments Int?
  payment_value Float?

  @@map("orderPayments")
  @@schema("raw")
}

model CleanOrderPayment {
  id Int @id @default(autoincrement())
  order_id String
  order CleanOrder @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: Cascade)
  payment_sequential Int
  payment_type String
  payment_installments Int
  payment_value Float

  @@map("orderPayments")
  @@schema("clean")
}

model RawItemOrder {
  id Int @id @default(autoincrement())
  order_item_id Int?
  order_id String?
  product_id String?
  seller_id String?
  shipping_limit_date DateTime?
  price Float?
  freight_value Float?
  
  @@map("itemOrders")
  @@schema("raw")
}

model CleanItemOrder {
  id Int @id @default(autoincrement())
  order_item_id Int
  order_id String
  order CleanOrder @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: Cascade)
  product_id String
  product CleanProduct @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: Cascade)
  seller_id String
  seller CleanSeller @relation(fields: [seller_id], references: [seller_id], onDelete: Cascade, onUpdate: Cascade)
  shipping_limit_date DateTime
  price Float
  freight_value Float
  
  @@map("itemOrders")
  @@schema("clean")
}

model RawCategName {
  product_category_name String @id
  product_category_name_english String?

  @@map("categoryNames")
  @@schema("raw")
}

model CleanCategName {
  product_category_name String @id
  product_category_name_english String
  products CleanProduct[]

  @@map("categoryNames")
  @@schema("clean")
}

model GoldFactSales {
  id Int @id @default(autoincrement())
  customer_id String
  customer GoldDimCustomer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade, onUpdate: Cascade)
  item_price Decimal
  freight_value Decimal
  payment_value_allocated Float 
  is_delivered Boolean
  is_canceled Boolean 
  is_on_time Boolean

  @@map("fact_sales")
  @@schema("gold")
}

model GoldDimCustomer {
  customer_id String @id
  customer_state String
  customer_city String

  fact_sales GoldFactSales[]
  @@map("dim_customer")
  @@schema("gold")
}